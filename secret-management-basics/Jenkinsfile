pipeline {
    agent { label 'agent-01' }

    stages {

        stage('Fetch Secrets & Build') {
            steps {
                withInfisical(
                    configuration: [
                        infisicalUrl: 'http://infisical:80',
                        infisicalCredentialId: 'jenkins-secret-management',
                        infisicalProjectSlug: 'java-secrets-management',
                        infisicalEnvironmentSlug: 'dev'
                    ],
                    infisicalSecrets: [
                        infisicalSecret(
                            path: '/',
                            includeImports: true,
                            secretValues: [
                                [infisicalKey: 'DB_PASSWORD'],
                                [infisicalKey: 'API_KEY'],
                                [infisicalKey: 'APP_ENV']
                            ]
                        )
                    ]
                ) {
                    dir('secrets-basics') {
                        sh 'gradle bootJar'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                withInfisical(
                    configuration: [
                        infisicalUrl: 'http://infisical:80',
                        infisicalCredentialId: 'java-secrets-management',
                        infisicalProjectSlug: 'java-secrets-management',
                        infisicalEnvironmentSlug: 'dev'
                    ],
                    infisicalSecrets: [
                        infisicalSecret(
                            path: '/',
                            includeImports: true,
                            secretValues: [
                                [infisicalKey: 'DB_PASSWORD'],
                                [infisicalKey: 'API_KEY'],
                                [infisicalKey: 'APP_ENV']
                            ]
                        )
                    ]
                ) {
                    sh '''
                        docker stop secrets-app || true
                        docker rm secrets-app || true
                        docker build -t secrets-app ./secrets-basics
                        docker run -d \
                          --name secrets-app \
                          -p 8080:8080 \
                          -e DB_PASSWORD=$DB_PASSWORD \
                          -e API_KEY=$API_KEY \
                          -e APP_ENV=$APP_ENV \
                          secrets-app
                    '''
                }
            }
        }
    }
}